milestones 1.7

# Progress stratum for route learning. Reaching the lower exit path is closer
# than reproducing control, but is not success until the transition commits.
milestone ordon_spring_exit_approach {
  phase post_sim
  when stage.name == "F_SP103" && stage.room == 1 &&
       player.exists && player.is_link &&
       player.in_aabb(-1900.0, 650.0, -4050.0, -1400.0, 900.0, -3800.0)
}
