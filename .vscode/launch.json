{
    "version": "0.2.0",
    "inputs": [
        {
            "id": "glitchHuntTape",
            "type": "promptString",
            "description": "DUSKTAPE path (relative to the repository or absolute)",
            "default": "build/boot_start_smoke.tape"
        }
    ],
    "configurations": [
        {
            "name": "Glitch Hunt: Visual TAS Playback",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/windows-clang-debug/dusklight.exe",
            "args": [
                "--configured-dvd",
                "--input-tape", "${input:glitchHuntTape}",
                "--input-tape-end", "hold",
                "--automation-data-root", "${workspaceFolder}/build/automation-state/vscode-debug",
                "--cvar", "game.instantSaves=true",
                "--cvar", "backend.cardFileType=1",
                "--cvar", "backend.wasPresetChosen=true",
                "--cvar", "game.enableMenuPointer=false",
                "--develop",
                "--console"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Glitch Hunt: Prepare Visual TAS",
            "postDebugTask": "Glitch Hunt: Clean Visual TAS State"
        },
        {
            "name": "(gdb) Launch Dusklight MSVC",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": ["-l", "1", "--dvd", "${workspaceRoot}/orig/GZ2E01/GZ2E01.iso", "--console"],
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "symbolSearchPath": "${command:cmake.launchTargetPath}",
            "console": "integratedTerminal",
            "cwd":"${workspaceRoot}"
        }
    ]
}
