{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Route Planner: Web UI",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/tools/route-planner/target/debug/route-planner.exe",
            "args": [
                "serve-web",
                "--listen", "127.0.0.1:32170",
                "--projects", "${workspaceFolder}/tools/route-planner/projects"
            ],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated",
            "preLaunchTask": "Route Planner: Build"
        },
        {
            "name": "Glitch Hunt: Route Workbench",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/tools/huntctl/target/debug/huntctl.exe",
            "args": [
                "timeline", "workbench",
                "--timeline", "${workspaceFolder}/routes/Glitch Exhibition/intro.timeline",
                "--game", "${workspaceFolder}/build/windows-clang-debug/dusklight.exe",
                "--world-context", "${workspaceFolder}/build/world/ordon.context.json",
                "--state-root", "${workspaceFolder}/build/automation-state/route-workbench"
            ],
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "preLaunchTask": "Glitch Hunt: Prepare Route Workbench"
        },
        {
            "name": "(gdb) Launch Dusklight MSVC",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${command:cmake.launchTargetPath}",
            "args": ["-l", "1", "--dvd", "${workspaceRoot}/orig/GZ2E01/GZ2E01.iso", "--console"],
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "symbolSearchPath": "${command:cmake.launchTargetPath}",
            "console": "integratedTerminal",
            "cwd":"${workspaceRoot}"
        },
        {
            "name": "Glitch Hunt: Route Workbench (macOS)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/tools/huntctl/target/debug/huntctl",
            "args": [
                "timeline", "workbench",
                "--timeline", "${workspaceFolder}/routes/Glitch Exhibition/intro.timeline",
                "--game", "${workspaceFolder}/build/macos-default-debug/Dusklight.app/Contents/MacOS/Dusklight",
                "--dvd", "${workspaceFolder}/orig/GZ2E01/GZ2E01.iso",
                "--world-context", "${workspaceFolder}/build/world/ordon.context.json",
                "--state-root", "${workspaceFolder}/build/automation-state/route-workbench"
            ],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated",
            "preLaunchTask": "Glitch Hunt: Prepare Route Workbench (macOS)"
        },
        {
            "name": "Launch Dusklight (macOS)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/build/macos-default-debug/Dusklight.app/Contents/MacOS/Dusklight",
            "args": ["-l", "1", "--dvd", "${workspaceFolder}/orig/GZ2E01/GZ2E01.iso", "--console"],
            "cwd": "${workspaceFolder}",
            "terminal": "integrated",
            "preLaunchTask": "Glitch Hunt: Build Dusklight (macOS)"
        }
    ]
}
