{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "glitchHuntTest",
      "type": "pickString",
      "description": "Glitch-hunting test suite",
      "default": "all",
      "options": [
        "all",
        "native",
        "automation-boundary",
        "input-tape",
        "gameplay-trace",
        "input-controller",
        "game-clock",
        "name-entry",
        "name-entry-trace",
        "rng",
        "eye-shredder-oracle",
        "eye-shredder",
        "intro-first-exit",
        "intro-cutscene",
        "fsp103-next-map-seed",
        "aurora-card",
        "aurora-time",
        "rust",
        "rust-lint",
        "worker-smoke",
        "pool-smoke"
      ]
    },
    {
      "id": "glitchHuntDvd",
      "type": "promptString",
      "description": "DVD image path; blank uses Dusklight's last manual selection",
      "default": ""
    },
    {
      "id": "glitchHuntScenario",
      "type": "pickString",
      "description": "Visual glitch-hunting scenario",
      "default": "eye-shredder",
      "options": [
        "eye-shredder",
        "intro-first-exit",
        "intro-cutscene",
        "fsp103-next-map-seed",
        "boot-search-champion",
        "route-search-champion",
        "boot-start-smoke"
      ]
    },
    {
      "id": "glitchHuntSearchSegment",
      "type": "pickString",
      "description": "Milestone-backed search objective",
      "default": "fsp103_to_fsp104",
      "options": [
        "fsp103_to_fsp104",
        "boot_to_fsp103"
      ]
    },
    {
        "id": "gameVersion",
        "type": "pickString",
        "options": [
            "GZ2E01",
            "GZ2P01",
            "GZ2J01",
            "RZDE01_00",
            "RZDE01_02",
            "RZDP01",
            "RZDJ01",
            "Shield",
            "ShieldD"
        ],
        "default": "GZ2E01",
        "description": "Game version to build."
    }
  ],
  "tasks": [
    {
      "label": "Glitch Hunt: Prepare Route Workbench",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Glitch Hunt: Configure Dusklight",
        "Glitch Hunt: Build Dusklight",
        "Glitch Hunt: Build Route Workbench"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Configure Dusklight",
      "type": "process",
      "command": "cmake",
      "args": [
        "--preset", "windows-clang-debug",
        "-DDUSK_ENABLE_CODE_MODS=OFF",
        "-DDUSK_ENABLE_AUTOMATION_OBSERVERS=ON",
        "-DDUSK_ENABLE_AUTOMATION_FIDELITY_MODELS=ON"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Dusklight",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build", "--preset", "windows-clang-debug",
        "--target", "dusklight"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Route Workbench",
      "type": "process",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path", "${workspaceFolder}/tools/huntctl/Cargo.toml"
      ],
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Run Selected Test",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\glitch-hunting\\run-tests.ps1",
        "-Test",
        "${input:glitchHuntTest}"
      ],
      "problemMatcher": "$msCompile",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Glitch Hunt: Run Search",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\glitch-hunting\\run-search.ps1",
        "-Segment",
        "${input:glitchHuntSearchSegment}",
        "-DvdPath",
        "${input:glitchHuntDvd}"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Glitch Hunt: Prepare Visual TAS",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\glitch-hunting\\prepare-visual-tas.ps1"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Glitch Hunt: Clean Visual TAS State",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\glitch-hunting\\cleanup-visual-tas.ps1"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Play Visual Scenario",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\tools\\glitch-hunting\\play-visual-scenario.ps1",
        "-DvdPath",
        "${input:glitchHuntDvd}",
        "-Scenario",
        "${input:glitchHuntScenario}",
        "-SkipBuild"
      ],
      "dependsOrder": "sequence",
      "dependsOn": "Glitch Hunt: Prepare Visual TAS",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "ninja",
      "type": "shell",
      "command": "ninja",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "configure",
      "type": "shell",
      "command": "${command:python.interpreterPath} configure.py --version ${input:gameVersion}",
      "problemMatcher": []
    },
    {
      "label": "ninja changes_all",
      "type": "shell",
      "command": "ninja changes_all",
      "problemMatcher": []
    }
  ]
}
