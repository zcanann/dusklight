{
  "version": "2.0.0",
  "inputs": [
    {
        "id": "gameVersion",
        "type": "pickString",
        "options": [
            "GZ2E01",
            "GZ2P01",
            "GZ2J01",
            "RZDE01_00",
            "RZDE01_02",
            "RZDP01",
            "RZDJ01",
            "Shield",
            "ShieldD"
        ],
        "default": "GZ2E01",
        "description": "Game version to build."
    }
  ],
  "tasks": [
    {
      "label": "Route Planner: Build",
      "type": "process",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path", "${workspaceFolder}/tools/route-planner/Cargo.toml",
        "--bin", "route-planner"
      ],
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Prepare Route Workbench",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Glitch Hunt: Configure Dusklight",
        "Glitch Hunt: Build Dusklight",
        "Glitch Hunt: Build Route Workbench"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Configure Dusklight",
      "type": "process",
      "command": "cmake",
      "args": [
        "--preset", "windows-clang-debug",
        "-DDUSK_ENABLE_CODE_MODS=OFF",
        "-DDUSK_ENABLE_AUTOMATION_OBSERVERS=ON",
        "-DDUSK_ENABLE_AUTOMATION_FIDELITY_MODELS=ON"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Dusklight",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build", "--preset", "windows-clang-debug",
        "--target", "dusklight"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Route Workbench",
      "type": "process",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path", "${workspaceFolder}/tools/huntctl/Cargo.toml"
      ],
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Prepare Route Workbench (macOS)",
      "dependsOrder": "sequence",
      "dependsOn": [
        "Glitch Hunt: Build Dusklight (macOS)",
        "Glitch Hunt: Build Route Workbench (macOS)"
      ],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Configure Dusklight (macOS)",
      "type": "process",
      "command": "cmake",
      "args": [
        "--preset", "macos-default-debug",
        "-DDUSK_ENABLE_CODE_MODS=OFF",
        "-DDUSK_ENABLE_AUTOMATION_OBSERVERS=ON",
        "-DDUSK_ENABLE_AUTOMATION_FIDELITY_MODELS=ON",
        "-DSQLite3_INCLUDE_DIR=/opt/homebrew/opt/sqlite/include",
        "-DSQLite3_LIBRARY=/opt/homebrew/opt/sqlite/lib/libsqlite3.dylib"
      ],
      "problemMatcher": "$gcc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Dusklight (macOS)",
      "type": "process",
      "command": "cmake",
      "args": [
        "--build", "--preset", "macos-default-debug",
        "--target", "dusklight"
      ],
      "problemMatcher": "$gcc",
      "dependsOn": "Glitch Hunt: Configure Dusklight (macOS)",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Glitch Hunt: Build Route Workbench (macOS)",
      "type": "process",
      "command": "cargo",
      "args": [
        "build",
        "--manifest-path", "${workspaceFolder}/tools/huntctl/Cargo.toml"
      ],
      "problemMatcher": "$rustc",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "ninja",
      "type": "shell",
      "command": "ninja",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "configure",
      "type": "shell",
      "command": "${command:python.interpreterPath} configure.py --version ${input:gameVersion}",
      "problemMatcher": []
    },
    {
      "label": "ninja changes_all",
      "type": "shell",
      "command": "ninja changes_all",
      "problemMatcher": []
    }
  ]
}
