milestones 1.3

# The target is a measured, reachable waypoint on the direct Ordon ranch route.
# Stability rejects a one-tick pass through the region.
milestone reach_point_ordon {
  phase post_sim
  stable 5
  when stage.name == "F_SP104" && stage.room == 1 &&
       player.exists && player.is_link &&
       player.in_aabb(-1200.0, 250.0, -9460.0, -1100.0, 310.0, -9360.0)
}
